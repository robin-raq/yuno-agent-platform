# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit it.
# I (Claude) only ever check that these are PRESENT (name + length), never read or echo the values.

# --- Agent runtime LLM provider (Goose native = anthropic) ---
# Funded key. Powers every agent's reasoning + tool calls.
ANTHROPIC_API_KEY=

# --- Demo narration TTS (OPTIONAL) ---
# If set, Phase 5 narration uses OpenAI TTS. If left blank, narration falls back to macOS `say`.
OPENAI_API_KEY=

# --- External messaging channel: Telegram ---
# From @BotFather: send /newbot, follow prompts, paste the HTTP API token here.
TELEGRAM_BOT_TOKEN=
# Your numeric chat id (DM the bot once, then I can resolve it via getUpdates — or get it from @userinfobot).
TELEGRAM_CHAT_ID=

# --- Telegram Payments pay-in (TEST mode) ---
# In @BotFather: /mybots -> your bot -> Payments -> connect "Stripe TEST MODE".
# It hands back a provider token (test tokens look like 12345:TEST:abcd...). No real money moves.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# --- Model selection (sane defaults; override if you like) ---
# Sonnet reliably handles multi-tool agent roles; haiku is cheaper but breaks persona
# on tool-using agents (it refuses/confabulates instead of calling tools).
GOOSE_PROVIDER=anthropic
GOOSE_MODEL=claude-sonnet-4-6
